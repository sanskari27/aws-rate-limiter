{
	"name": "aws-rate-limiter",
	"version": "1.0.0",
	"description": "Production-grade multi-dimensional rate limiter for AWS Lambda and EC2/ECS",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"test": "npm run test:coverage && npm run test:mutation",
		"test:unit": "jest --testPathPattern=tests/unit",
		"test:integration": "jest --testPathPattern=tests/integration",
		"test:coverage": "jest --coverage",
		"test:mutation": "stryker run",
		"lint": "eslint src --ext .ts",
		"clean": "rm -rf dist",
		"prepare": "husky"
	},
	"dependencies": {
		"@aws-sdk/client-cloudwatch": "^3.0.0",
		"@aws-sdk/client-ssm": "^3.0.0",
		"ioredis": "^5.3.2",
		"js-yaml": "^4.1.0",
		"minimatch": "^9.0.0"
	},
	"devDependencies": {
		"@stryker-mutator/core": "^9.6.0",
		"@stryker-mutator/jest-runner": "^9.6.0",
		"@stryker-mutator/typescript-checker": "^9.6.0",
		"@types/jest": "^29.5.0",
		"@types/js-yaml": "^4.0.9",
		"@types/minimatch": "^5.1.2",
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"eslint": "^10.1.0",
		"husky": "^9.1.7",
		"jest": "^29.5.0",
		"lint-staged": "^16.4.0",
		"ts-jest": "^29.1.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.0.0"
	},
	"lint-staged": {
		"src/**/*.ts": [
			"eslint --fix",
			"jest --coverage --findRelatedTests --passWithNoTests"
		]
	},
	"engines": {
		"node": ">=18.x"
	}
}
